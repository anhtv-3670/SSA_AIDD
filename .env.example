# Copy to .env.local and fill with your local Supabase values (`supabase status -o env`).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# OAuth (optional — only to use Google/GitHub login). Set before `supabase start`.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Dev test login (auto-pass OAuth). Shows a "Đăng nhập test (dev)" button that signs in
# the seeded account (supabase/seed.sql) via password auth — no Google round-trip.
# NEVER set in production: it is also hard-disabled when NODE_ENV=production.
ENABLE_TEST_LOGIN=true
# Optional overrides (default to the seed account):
# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=password123
